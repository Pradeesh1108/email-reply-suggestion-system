# ─── Groq API ────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here

# Model per role — override to trade cost vs quality (see README §Cost-Control)
# Default: openai/gpt-oss-120b  |  Cheaper fallback: openai/gpt-oss-20b
GROQ_MODEL_GENERATOR=openai/gpt-oss-120b
GROQ_MODEL_JUDGE=openai/gpt-oss-120b

# ─── Retrieval ────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=3
RETRIEVAL_CONFIDENCE_THRESHOLD=0.15

# ─── Evaluation ───────────────────────────────────────────────────────────────
# Equal weights across the 4 judge axes (must sum to 1.0)
WEIGHT_RELEVANCE=0.25
WEIGHT_GROUNDEDNESS=0.25
WEIGHT_TONE=0.25
WEIGHT_COMPLETENESS=0.25

# Penalty subtracted from composite per hard rule-based failure (on 5-point scale)
RULE_HARD_FAILURE_PENALTY=1.0

# Composite score threshold for "pass" in holdout reporting
PASS_THRESHOLD=3.0

# ─── Judge stability (offline/calibration mode only) ──────────────────────────
STABILITY_RERUNS=3

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///backend/data/history.db
CACHE_DB_PATH=backend/data/cache.db
